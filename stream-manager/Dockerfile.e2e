# E2E Test Runner Dockerfile
# Runs E2E tests against the stream-manager service

FROM node:18-alpine

WORKDIR /app

# Install curl for API testing
RUN apk add --no-cache curl bash

# Copy package files and install all dependencies (including dev)
COPY package*.json ./
RUN npm ci

# Copy test files
COPY tests/ ./tests/
COPY vitest.config.ts ./
COPY tsconfig*.json ./

# Copy source for type resolution (tests import from src)
COPY src/ ./src/

# Run E2E tests
CMD ["npm", "run", "test:e2e"]
